{
  "private": true,
  "scripts": {
    "build:css": "esbuild assets/css/*.css --outdir=static/css --minify --out-extension:.css=.min.css",
    "build:js": "esbuild assets/js/*.js --outdir=static/js --minify --out-extension:.js=.min.js",
    "build": "pnpm build:css && pnpm build:js",
    "lint": "markdownlint-cli2 \"content/**/*.md\"",
    "spellcheck": "cspell --no-progress \"content/**/*.md\""
  },
  "devDependencies": {
    "@cspell/dict-de-de": "^4.1.2",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@cspell/dict-grc": "^1.0.7",
    "@cspell/dict-it-it": "^3.1.6",
    "@cspell/dict-la": "^1.1.2",
    "cspell": "^9.7.0",
    "esbuild": "^0.28.0",
    "markdownlint-cli2": "^0.22.0"
  }
}
