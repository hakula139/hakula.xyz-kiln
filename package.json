{
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "tailwindcss -i static/css/_src/main.css -o static/css/style.css",
    "dev": "tailwindcss -i static/css/_src/main.css -o static/css/style.css --watch",
    "format": "prettier --check .",
    "lint": "pnpm lint:md && pnpm lint:js",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2 \"content/**/*.md\"",
    "spellcheck": "cspell --no-progress \"content/**/*.md\""
  },
  "devDependencies": {
    "@cspell/dict-de-de": "^4.1.2",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@cspell/dict-grc": "^1.0.7",
    "@cspell/dict-it-it": "^3.1.6",
    "@cspell/dict-la": "^1.1.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "cspell": "^10.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "wrangler": "^4.90.0"
  }
}
